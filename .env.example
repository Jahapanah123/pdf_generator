SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=120s

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pdfgen
DB_SSL_MODE=disable
DB_MAX_CONNS=50
DB_MIN_CONNS=10

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_JOB_EXCHANGE=pdf_jobs_exchange
RABBITMQ_JOB_QUEUE=pdf_jobs
RABBITMQ_JOB_DLQ=pdf_jobs_dlq
RABBITMQ_EVENT_EXCHANGE=job_events
RABBITMQ_PREFETCH=10

JWT_ACCESS_SECRET=change-me-access-secret-32chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-32chars!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

WORKER_CONCURRENCY=10
WORKER_MAX_RETRIES=3

RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40

PDF_OUTPUT_DIR=./output

SSE_MAX_CONNECTIONS=10000
SSE_CLIENT_BUFFER=16